# ============================================================
# IEDC Student Engagement Portal — Environment Variables
# ============================================================

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME="IEDC Portal"

# Database (Supabase PostgreSQL)
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres

# Better Auth
BETTER_AUTH_SECRET=generate-with-openssl-rand-base64-32
BETTER_AUTH_URL=http://localhost:3000

# Allowed Student Domain (students must register with this email domain)
ALLOWED_STUDENT_DOMAIN=@sjcetpalai.ac.in

# Redis (Upstash) — optional, leaderboard works without it
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Email (Resend) — optional, logs to console if not set
RESEND_API_KEY=
EMAIL_FROM=noreply@iedc.college.edu.in

# QR Security
QR_GLOBAL_PEPPER=generate-with-openssl-rand-hex-32
